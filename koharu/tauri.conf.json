{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Manga Offline Translate",
  "identifier": "com.mattlifetech.mangaofflinetranslate",
  "build": {
    "beforeDevCommand": "npm --prefix ui run dev",
    "beforeBuildCommand": "npm --prefix ui run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../ui/out"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "visible": false,
        "width": 1024,
        "height": 768,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "title": "Manga Offline Translate",
        "decorations": false
      },
      {
        "label": "splashscreen",
        "url": "/splashscreen",
        "decorations": false,
        "resizable": false,
        "height": 200,
        "width": 300,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../LICENSE", "../NOTICE.md"],
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGNjJGMTlEODk0MjkwMjMKUldRamtFS0puZkZpN3hWZ1BVSkoyUEd1N1RvV09DL01XK2FmcEZOM1R4eGh5cDZ6dEVrTzJNSW4K",
      "endpoints": [
        "https://github.com/mattlifetech/manga-offline-translate/releases/latest/download/latest.json"
      ]
    }
  }
}
